# ─── APPLICATION ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=catalyst
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── BACKEND API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ─── POSTGRESQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=catalyst
POSTGRES_USER=catalyst
POSTGRES_PASSWORD=catalyst_dev_password
DATABASE_URL=postgresql+asyncpg://catalyst:catalyst_dev_password@localhost:5432/catalyst

# ─── NEO4J ───────────────────────────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=catalyst_neo4j_password

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── CELERY ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# ─── GITHUB INTEGRATION ──────────────────────────────────────────────────────
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_API_URL=https://api.github.com

# ─── OPENTELEMETRY ───────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=catalyst-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SDK_DISABLED=false

# ─── JAEGER ──────────────────────────────────────────────────────────────────
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ─── PROMETHEUS ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8001
METRICS_ENABLED=true

# ─── ML / PYTORCH ────────────────────────────────────────────────────────────
TORCH_DEVICE=cpu
MODEL_REGISTRY_PATH=./models
MAX_GRAPH_NODES=50000

# ─── FRONTEND ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=Catalyst
VITE_APP_VERSION=0.1.0
